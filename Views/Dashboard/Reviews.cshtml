@model List<RestaurantReview>
@{
	int reviewsCount = Model.Count;
}

<div class="row">
	<div class="col">
		<h2 class="mb-4">@SharedLocalizer["common.RestaurantReviews"]</h2>
		
		
			@if (reviewsCount > 0)
			{
					<h4 class="text-warning"> @SharedLocalizer["common.RestaurantReviewsCount"] : @reviewsCount.ToString() </h4>
			}
			else
			{
				<h4 class="text-danger"> @SharedLocalizer["common.NoRestaurantReviews"] </h4>
			}
				
	</div>
</div>

@foreach(var review in Model)
{
		<div class="row mt-2">
		<div class="col">
			<div class="card ps-3">

				<div>
					<div class="d-flex gap-2 mt-2">
						<h3>@(review.User.FirstName + " " +  review.User.LastName)</h3>
						@for(byte star = review.Rating; star > 0; star-- )
						{
							<span class="text-primary pe-2"><i class="bi bi-star-fill"></i></span>

						}
					</div>
					<span class="text-muted">@review.CreatedAt.ToString()</span>
				</div>

				<div class="mt-3 mb-3">
					<span>@review.Comment</span>
				</div>
			</div>
		</div>
	</div>
}