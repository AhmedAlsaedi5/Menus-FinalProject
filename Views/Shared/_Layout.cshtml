@{
    bool isRTL = CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    string htmlDir = isRTL ? "rtl" : "ltr";
    var htmlLang = CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
}


<!DOCTYPE html>
<html dir="@htmlDir"  lang="@htmlLang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - menus_project</title>

    <!-- Bootstrap -->
    @if (isRTL)
    {
            <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    }
    else
    {
            <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/menus_project.styles.css" asp-append-version="true" />
</head>
<body >

    <header>
        <nav class="navbar navbar-expand-sm border-bottom">
            <div class="container-fluid d-flex align-items-center">
    

                <a class="navbar-brand" asp-controller="Home" asp-action="Index"> Menus <i class="bi bi-card-text"></i> </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>
    
                <div class="collapse navbar-collapse" id="navbarContent">
    
                    <ul class="navbar-nav mx-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1"></i>
                                @SharedLocalizer["Nav.Home"]
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="FavoriteRestaurants">
                                <i class="bi bi-heart"></i>
                                @SharedLocalizer["Nav.FavoriteRestaurants"]
                            </a>
                        </li>
                    </ul>
    
    
                    <div class="d-flex align-items-center gap-2">
    
    
                        <partial name="_SelectLanguage" />
    
                        <div class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white text-decoration-none" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-person-circle me-1"></i>
                                        @if (SignInManager.IsSignedIn(User))
                                        {
                                            var user = await UserManager.GetUserAsync(User);
                                        <span>@user?.FirstName</span>
                                        }
                                        else
                                        {
                                        <span>@SharedLocalizer["Common.Guest"]</span>
                                        }
                            </a>
    
                            <ul class="dropdown-menu dropdown-menu-end">
                                        @if (SignInManager.IsSignedIn(User))
                                        {
                                        <li>
                                        @if (User.IsInRole(menus_project.Constants.AppRoles.RestaurantOwner))
                                        {
                                              <a class="dropdown-item" asp-controller="Dashboard" asp-action="Index">
                                                 <i class="bi bi-speedometer2 me-2"></i>
                                                 @SharedLocalizer["common.Dashboard"]
                                             </a>
                                        }
                                       
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                                <i class="bi bi-person me-2"></i>
                                                    @SharedLocalizer["common.Profile"]
                                            </a>
                                        </li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li>
                                            <form asp-controller="Account" asp-action="Logout" method="post">
                                                    @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger">
                                                    <i class="bi bi-box-arrow-right me-2"></i>
                                                        @SharedLocalizer["common.Logout"]
                                                </button>
                                            </form>
                                        </li>
                                        }
                                        else
                                        {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Account" asp-action="Login">
                                                <i class="bi bi-box-arrow-in-right me-2"></i>
                                                    @SharedLocalizer["common.Login"]
                                            </a>
                                        </li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Account" asp-action="Register">
                                                <i class="bi bi-person-plus me-2"></i>
                                                    @SharedLocalizer["common.Register"]
                                            </a>
                                        </li>
                                        }
                            </ul>
                        </div>
    
                    </div>
                </div>
            </div>
        </nav>
    </header>


    @if (SignInManager.IsSignedIn(User) && User.IsInRole("RestaurantOwner"))
    {
                <div class="dashboard-wrapper">
                        <partial name="_DashboardLayout" />
                    <main class="sidebar-content">
                     @RenderBody()
                    </main>
                </div>
    }
    else
    {
                <div class="container">
                    <main class="pb-3">
                @RenderBody()
                    </main>
                </div>
    }

    <footer class="bg-primary text-white py-4 mt-5 ">

        <div class="container">
            <div class="row">
                <div class="col">

                <ul class="list-unstyled">
                    <li><h5>@SharedLocalizer["footer.QuickLinks"]</h5></li>
                </ul>

                <ul class="list-unstyled ">
                    <li><a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none">@SharedLocalizer["Nav.Home"]</a></li>
                    <li><a href="#" class="text-white text-decoration-none">@SharedLocalizer["footer.Services"]</a></li>
                    <li><a href="#" class="text-white text-decoration-none">@SharedLocalizer["footer.ContactUs"]</a></li>
                </ul>
            </div>
                <div class="col">
                    <ul class="list-inlin list-unstyled">

                        <li><h5>@SharedLocalizer["footer.FollowUs"]</h5></li>
                        <li class="list-inline-item"> <a href="#" class="text-white "><i class="bi bi-instagram"></i></a></li>
                        <li class="list-inline-item"><a href="#" class="text-white me-2"><i class="bi bi-twitter-x"></i></a></li>

                    </ul>
                </div>
                <div class="col">
                  <ul class="list-unstyled">
                        <li><h5>@SharedLocalizer["footer.Contact"]</h5></li>
                        <li><p>info@example.com</p></li>
                        <li><p>+966 5xxxxxxxx</p></li>
                        <li><p> &copy; هذا الموقع للعرض فقط</p></li>
                    </ul>
                </div>
             </div>
        </div>


    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

