@model menus_project.ViewModel.RestaurantReviewViewModel
@{
	int reviewsCount = Model.RestaurantReviews.Count;
	bool isRTL = CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
}

<div class="row mt-3 mb-5">
			<div class="col ">
				<div class="card no-hover ">

					<div class="row">
						<div class="col-3">
							<img src="~/Images/@Model.Restaurant.Image_url"  height=125 class="rounded w-100" />
						</div>
						<div class="col">
							<div class="ps-2 d-flex justify-content-between">
								<h4 class="card-title">@(isRTL ? Model.Restaurant.NameInArabic : Model.Restaurant.Name)</h4>

							</div>
							<div>
								<div class="d-flex gap-1 ps-2"> 


							@if (Model.Restaurant.AverageRating > 3)
							{
														<small class="text-warning"><i class="bi bi-star-fill"></i></small>
							}
							else if (Model.Restaurant.AverageRating > 1)
							{
																<small class="text-warning"><i class="bi bi-star-half"></i</small>
							}
							else
							{
																		<small class="text-warning"> <i class="bi bi-star"></i></small>
							}
									<small class="text-secondary"> @Model.Restaurant.AverageRating.ToString() (@Model.Restaurant.ReviewCount)</small>	
								</div>
								<div>
									<div class="d-flex gap-2  ps-2 mt-2 ">
								@foreach (var category in Model.Restaurant.RestaurantCategories)
								{
												<span class="badge-category mb-3">@(isRTL ? category.NameInArabic : category.Name)</span>
								}
									</div>
								</div>

							</div>
						</div>	
					</div>
				</div>
			</div>
			<div class="mt-3 ">
					<form asp-action="AddRestaurantReview" method="post">
							@Html.AntiForgeryToken()
							<input type="hidden" asp-for="RestaurantId" />

			@if (!Model.IsReviewed && User.IsInRole(menus_project.Constants.AppRoles.User))
							{
								<h3>أضف تعليق</h3>
										<div class="rating">
											@for (int i = 5; i >= 1; i--)
											{
												<input type="radio"
											   asp-for="AddRestaurantReview.Rating"
											   id="star@(i)"
											   value="@i" />
						
												<label for="star@(i)">★</label>
											}
										</div>
						
							<span asp-validation-for="AddRestaurantReview.Rating" class="text-danger"></span>
								<div>
									<textarea rows="3" cols="90" placeholder="@SharedLocalizer["common.EnterComment"]" asp-for="AddRestaurantReview.Comment"></textarea>
										<span asp-validation-for="AddRestaurantReview.Comment" class="text-danger"></span>

								</div>
									<button class="btn btn-primary mt-2">@SharedLocalizer["Common.Save"]</button>
							}

							 </form>
			</div>
							
		</div>

<div class="row">
	<div class="col">
		<h2 class="mb-4">@SharedLocalizer["common.RestaurantReviews"]</h2>
		
		
			@if (reviewsCount > 0)
			{
					<h4 class="text-warning"> @SharedLocalizer["common.RestaurantReviewsCount"] : @reviewsCount.ToString() </h4>
			}
			else
			{
				<h4 class="text-danger"> @SharedLocalizer["common.NoRestaurantReviews"] </h4>
			}
				
	</div>
</div>

@foreach(var review in Model.RestaurantReviews)
{
		<div class="row mt-2">
		<div class="col">
			<div class="card ps-3">

				<div>
					<div class="d-flex gap-2 mt-2">
						<h3>@(review.User.FirstName + " " +  review.User.LastName)</h3>
						@for(byte star = review.Rating; star > 0; star-- )
						{
							<span class="text-primary pe-2"><i class="bi bi-star-fill"></i></span>

						}
					</div>
					<span class="text-muted">@review.CreatedAt.ToString()</span>
				</div>

				<div class="mt-3 mb-3">
					<span>@review.Comment</span>
				</div>
			</div>
		</div>
	</div>
}